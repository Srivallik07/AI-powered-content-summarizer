# Optional Groq API key. Set this to use Groq for summarization.
GROQ_API_KEY=
GROQ_MODEL=gpt-4o-mini

# Optional Gemini / Google Generative Language API key.
# Leave blank to use the built-in local summarizer instead.
GEMINI_API_KEY=
MODEL_NAME=text-bison-001

MONGODB_URI=your_mongodb_connection_string
